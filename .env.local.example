# ── STRIPE ──────────────────────────────────────────
# Crea tu cuenta en https://stripe.com (selecciona España)
# Habilita Bizum en: Dashboard → Settings → Payment methods → Bizum
# Copia las claves desde: Dashboard → Developers → API keys

STRIPE_SECRET_KEY=sk_live_...          # o sk_test_... para pruebas
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Para el webhook (necesitas Stripe CLI o un servidor con HTTPS):
# stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── APP ──────────────────────────────────────────────
# URL pública de tu web (para los redirects de Stripe)
NEXT_PUBLIC_BASE_URL=https://tu-dominio.com

# Contraseña del panel de administrador
NEXT_PUBLIC_ADMIN_PASSWORD=cambia-esto-por-algo-seguro
